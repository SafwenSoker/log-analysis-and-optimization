# Copy this file to .env and fill in your values

# Anthropic API key (required for Claude-powered analysis)
ANTHROPIC_API_KEY=sk-ant-...

# Jenkins integration (optional — needed for /jenkins/fetch endpoint)
JENKINS_URL=http://your-jenkins-host:8080
JENKINS_USER=admin
JENKINS_TOKEN=your-jenkins-api-token

# App settings
LOG_DIR=data/logs
DB_PATH=data/analysis.db
